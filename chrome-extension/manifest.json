{
  "manifest_version": 3,
  "name": "Token Savings Analyzer",
  "description": "Analyze prompt token savings and track optimization history.",
  "version": "1.0.0",
  "permissions": ["storage"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "action": {
    "default_title": "Token Savings Analyzer",
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}
